{
  "name": "@andhikapraa/qris",
  "version": "0.1.0",
  "description": "Zero-dependency QRIS parser, validator, and static→dynamic converter for Indonesian EMVCo payment codes",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "qris": "./dist/cli.cjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "cli": "tsx src/cli.ts",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "qris",
    "qr-code",
    "payment",
    "indonesia",
    "emvco",
    "gpn",
    "static-to-dynamic"
  ],
  "author": "Muhammad Andhika Prasetya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andhikapraa/qris"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
